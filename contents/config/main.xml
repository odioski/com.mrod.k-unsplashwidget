<?xml version="1.0" encoding="UTF-8"?>
<kcfg name="UnsplashWallpaperConfig">
  <group name="General">
    <entry name="changeWallpaper" type="Bool">
      <default>true</default>
    </entry>
    <entry name="intervalMinutes" type="Int">
      <default>30</default>
    </entry>
    <entry name="category" type="String">
      <default>nature</default>
    </entry>
    <entry name="customCategories" type="String">
      <default></default>
    </entry>
    <entry name="resolutionWidth" type="Int">
      <default>1920</default>
    </entry>
    <entry name="resolutionHeight" type="Int">
      <default>1080</default>
    </entry>
    <entry name="backendUrl" type="String">
      <default>http://127.0.0.1:8787/api/random-photo</default>
    </entry>
    <entry name="enableSavedDownloads" type="Bool">
      <default>false</default>
    </entry>
    <entry name="downloadDirectory" type="String">
      <default></default>
    </entry>
  </group>
</kcfg>
