#!/usr/bin/env bash
set -euo pipefail

PLUGIN_ID="K-Splash"
SRC_DIR="$SNAP/usr/share/plasma/plasmoids/$PLUGIN_ID"
XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
DEST_DIR="$XDG_DATA_HOME/plasma/plasmoids/$PLUGIN_ID"
TMP_DIR="$(mktemp -d)"
RESTART_PLASMA="${1:-}"

cleanup() {
  rm -rf "$TMP_DIR"
}

trap cleanup EXIT

if [[ ! -d "$SRC_DIR" ]]; then
  echo "Packaged plasmoid not found: $SRC_DIR" >&2
  exit 1
fi

mkdir -p "$XDG_DATA_HOME/plasma/plasmoids"
mkdir -p "$TMP_DIR/$PLUGIN_ID"
cp -a "$SRC_DIR/." "$TMP_DIR/$PLUGIN_ID/"

# Preserve local backend config from an existing install.
if [[ -f "$DEST_DIR/contents/config/local.json" ]]; then
  mkdir -p "$TMP_DIR/$PLUGIN_ID/contents/config"
  cp "$DEST_DIR/contents/config/local.json" "$TMP_DIR/$PLUGIN_ID/contents/config/local.json"
fi

rm -rf "$DEST_DIR"
mkdir -p "$DEST_DIR"
cp -a "$TMP_DIR/$PLUGIN_ID/." "$DEST_DIR/"

echo "Installed $PLUGIN_ID to $DEST_DIR"
echo "Run this to reload Plasma shell:"
echo "  kquitapp6 plasmashell && kstart plasmashell"

if [[ "$RESTART_PLASMA" == "--restart" ]]; then
  if command -v kquitapp6 >/dev/null 2>&1 && command -v kstart >/dev/null 2>&1; then
    kquitapp6 plasmashell
    kstart plasmashell
  else
    echo "Plasma restart tools not found. Restart plasmashell manually." >&2
  fi
fi
